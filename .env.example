# ===== Pact Environment Variables =====
# Copy this file to .env and fill in your values

# Sepolia RPC (Alchemy/Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Contract deployment (deployer private key - KEEP SECRET)
DEPLOYER_PRIVATE_KEY=0x...

# USDC contract address (Sepolia testnet)
USDC_ADDRESS=0x38cFa1c54105d5382e4F3689af819116977A40Ce

# Agent wallet (EOA that signs UserOps)
AGENT_WALLET_ADDRESS=0x...
AGENT_PRIVATE_KEY=0x...

# Pimlico bundler (ERC-4337)
PIMLICO_API_KEY=your_pimlico_key

# GitHub (for PR watcher)
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo

# OpenRouter (for LLM scorer)
OPENROUTER_API_KEY=sk-or-...

# Python agents
ONCHAIN_SERVICE_URL=http://localhost:3001
